{
  "version": 1,
  "default": {
    "provider": "copilot"
  },
  "providers": {
    "copilot": {
      "command": "copilot",
      "useStdin": false,
      "env": {
        "NO_COLOR": "1",
        "FORCE_COLOR": "0"
      },
      "vars": {
        "model": ""
      },
      "args": [
        "-p",
        "{prompt}",
        "--allow-all-tools",
        "--no-ask-user",
        "-s",
        "--no-color"
      ],
      "argsIf": {
        "model": [
          "--model",
          "{model}"
        ]
      }
    },
    "claude": {
      "command": "claude",
      "useStdin": true,
      "env": {
        "NO_COLOR": "1",
        "FORCE_COLOR": "0"
      },
      "vars": {
        "model": "claude-haiku-4-5"
      },
      "args": [
        "-p",
        "--output-format",
        "text",
        "--permission-mode",
        "bypassPermissions"
      ],
      "argsIf": {
        "model": [
          "--model",
          "{model}"
        ],
        "maxTurns": [
          "--max-turns",
          "{maxTurns}"
        ]
      }
    },
    "cursor": {
      "command": "agent",
      "useStdin": true,
      "env": {
        "NO_COLOR": "1",
        "FORCE_COLOR": "0"
      },
      "vars": {
        "model": "GLM-4.7"
      },
      "args": [
        "-p",
        "--output-format",
        "text",
        "--force"
      ],
      "argsIf": {
        "model": [
          "--model",
          "{model}"
        ]
      }
    },
    "cline": {
      "command": "cline",
      "useStdin": false,
      "env": {
        "NO_COLOR": "1",
        "CI": "1"
      },
      "vars": {
        "model": "glm-4.7"
      },
      "args": [
        "-y"
      ],
      "argsIf": {
        "model": [
          "--model",
          "{model}"
        ],
        "prompt": [
          "{prompt}"
        ]
      }
    }
  }
}
